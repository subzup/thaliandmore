<header class="navbar" id="navbar">
  <div class="container navbar__inner">
    <a href="/" class="navbar__brand" aria-label="<%= site.name %> home">
      <span class="navbar__logo">
        <%- include('./icon', { name: 'leaf' }) %>
      </span>
      <span class="navbar__name"><%= site.name %></span>
    </a>

    <nav class="navbar__nav" id="navMenu" aria-label="Primary">
      <% site.nav.forEach(function(item) { %>
        <a href="<%= item.href %>" class="navbar__link <%= meta.path === item.href ? 'is-active' : '' %>"><%= item.label %></a>
      <% }); %>
    </nav>

    <div class="navbar__actions">
      <a href="tel:<%= site.contact.phoneHref %>" class="navbar__icon-btn" aria-label="Call us">
        <%- include('./icon', { name: 'phone' }) %>
      </a>
      <a href="#trial" class="btn btn--primary btn--sm navbar__cta">Start 7-Day Trial</a>
      <button type="button" class="navbar__toggle" id="navToggle" aria-label="Toggle menu" aria-expanded="false" aria-controls="navMenu">
        <%- include('./icon', { name: 'menu', cls: 'icon-open' }) %>
        <%- include('./icon', { name: 'x', cls: 'icon-close' }) %>
      </button>
    </div>
  </div>
</header>
