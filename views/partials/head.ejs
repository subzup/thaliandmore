<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= meta.title %></title>
<meta name="description" content="<%= meta.description %>">
<link rel="canonical" href="<%= meta.url %>">
<meta name="robots" content="index, follow">
<meta name="author" content="<%= site.name %>">

<!-- Open Graph -->
<meta property="og:type" content="website">
<meta property="og:title" content="<%= meta.title %>">
<meta property="og:description" content="<%= meta.description %>">
<meta property="og:url" content="<%= meta.url %>">
<meta property="og:site_name" content="<%= site.name %>">
<meta property="og:image" content="<%= meta.ogImage %>">
<meta property="og:locale" content="en_IN">

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="<%= meta.title %>">
<meta name="twitter:description" content="<%= meta.description %>">
<meta name="twitter:image" content="<%= meta.ogImage %>">

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/images/icons/favicon.svg">

<!-- Fonts: preconnect for performance -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<!-- Styles -->
<link rel="stylesheet" href="/css/style.css">

<!-- Schema.org: LocalBusiness / FoodEstablishment -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FoodEstablishment",
  "name": "<%= site.name %>",
  "image": "<%= meta.ogImage %>",
  "url": "<%= site.url %>",
  "telephone": "<%= site.contact.phoneHref %>",
  "servesCuisine": "Indian, Home-Style, Vegetarian",
  "priceRange": "₹₹",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "<%= site.kitchen.addressLine %>",
    "addressRegion": "<%= site.kitchen.addressRegion %>",
    "postalCode": "<%= site.kitchen.postalCode %>",
    "addressCountry": "<%= site.kitchen.country %>"
  },
  "areaServed": <%- JSON.stringify(site.locales) %>,
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "<%= site.stats.avgRating %>",
    "reviewCount": "<%= site.stats.reviewCount %>"
  }
}
</script>
